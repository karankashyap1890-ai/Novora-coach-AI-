# ============================================================
# NOVORA — Environment Configuration (100% Offline)
# ============================================================
# Copy this file to .env — NO API KEYS REQUIRED!

# ----- App -----
APP_NAME=Novora
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars

# ----- Server -----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
MCP_PORT=3001
FRONTEND_URL=http://localhost:3000

# ----- Database -----
DATABASE_URL=sqlite+aiosqlite:///./novora.db

# ----- JWT Auth -----
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ----- Rate Limiting -----
RATE_LIMIT_PER_MINUTE=60

# ----- CORS -----
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ----- Pomodoro Defaults -----
WORK_MINUTES=25
SHORT_BREAK_MINUTES=5
LONG_BREAK_MINUTES=15
SESSIONS_BEFORE_LONG_BREAK=4

# ----- Agent System (Offline) -----
# Controls agent response personality:  "warm" | "professional" | "playful"
COACH_PERSONALITY=warm
# Response latency simulation (ms) — makes agents feel more realistic
AGENT_RESPONSE_DELAY_MS=600
